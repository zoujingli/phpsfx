# min：最小组件集合。
# 该文件只使用“默认赋值”，调用方仍可通过环境变量显式覆盖任一项。

: "${PHPSFX_PROFILE_NAME:=min}"

: "${PHPSFX_EXTENSIONS:=bcmath,ctype,curl,dom,fileinfo,filter,iconv,mbstring,mysqlnd,openssl,pcntl,pdo,pdo_mysql,phar,posix,redis,simplexml,sockets,sodium,swoole,tokenizer,xml,xmlreader,xmlwriter,zip,zlib}"
: "${PHPSFX_REQUIRED_EXTENSIONS:=swoole,redis,pdo,pdo_mysql,mysqlnd,openssl,curl,mbstring,phar,zlib,zip,dom,simplexml,xmlreader,xmlwriter,fileinfo,bcmath,sodium,sockets,posix,pcntl}"
: "${PHPSFX_FORBIDDEN_EXTENSIONS:=bz2,exif,gd,gettext,gmp,imagick,intl,mongodb,mysqli,readline,session,soap,sqlite3,xlswriter,xsl,yaml,opcache}"
: "${PHPSFX_SWOOLE_CLI_PREPARE_FLAGS:=+bcmath +ctype +curl +fileinfo +filter +iconv +mbstring +mysqlnd +openssl +pcntl +pdo +pdo_mysql +phar +posix +redis +sockets +sodium +swoole +tokenizer +xml +zip +zlib -bz2 -exif -gd -gettext -gmp -imagick -intl -mongodb -mysqli -opcache -readline -session -soap -sqlite3 -xlswriter -xsl -yaml}"
: "${PHPSFX_SWOOLE_CLI_ENABLED_EXTENSIONS:=bcmath,ctype,curl,fileinfo,filter,iconv,mbstring,mysqlnd,openssl,pcntl,pdo,pdo_mysql,phar,posix,redis,sockets,sodium,swoole,tokenizer,xml,zip,zlib}"

# 最小集合会裁剪 Swoole/curl/libzip/zlib 的可选依赖。
: "${PHPSFX_SWOOLE_SLIM_EXTENSION:=1}"
: "${PHPSFX_CURL_SLIM_LIBRARY:=1}"
: "${PHPSFX_LIBZIP_SLIM_LIBRARY:=1}"
: "${PHPSFX_ZLIB_SLIM_LIBRARY:=1}"
: "${PHPSFX_REDIS_DISABLE_SESSION:=1}"
: "${PHPSFX_ONIGURUMA_CLANG_COMPAT:=1}"
