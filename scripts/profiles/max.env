# max：Swoole CLI 官方默认组件集合。
# 该文件只使用“默认赋值”，调用方仍可通过环境变量显式覆盖任一项。

: "${PHPSFX_PROFILE_NAME:=max}"

: "${PHPSFX_EXTENSIONS:=opcache,curl,iconv,bz2,bcmath,pcntl,filter,session,tokenizer,mbstring,ctype,zlib,zip,posix,sockets,pdo,sqlite3,phar,mysqlnd,mysqli,intl,fileinfo,pdo_mysql,soap,xsl,gmp,exif,sodium,openssl,readline,xml,gd,redis,swoole,yaml,imagick,mongodb,xlswriter,gettext}"
: "${PHPSFX_REQUIRED_EXTENSIONS:=opcache,curl,iconv,bz2,bcmath,pcntl,filter,session,tokenizer,mbstring,ctype,zlib,zip,posix,sockets,pdo,sqlite3,phar,mysqlnd,mysqli,intl,fileinfo,pdo_mysql,soap,xsl,gmp,exif,sodium,openssl,readline,xml,gd,redis,swoole,yaml,imagick,mongodb,xlswriter,gettext}"
: "${PHPSFX_FORBIDDEN_EXTENSIONS:=}"
: "${PHPSFX_SWOOLE_CLI_PREPARE_FLAGS:=}"
: "${PHPSFX_SWOOLE_CLI_ENABLED_EXTENSIONS:=}"

# max 不裁剪官方扩展和依赖库。
: "${PHPSFX_SWOOLE_SLIM_EXTENSION:=0}"
: "${PHPSFX_CURL_SLIM_LIBRARY:=0}"
: "${PHPSFX_LIBZIP_SLIM_LIBRARY:=0}"
: "${PHPSFX_ZLIB_SLIM_LIBRARY:=0}"
: "${PHPSFX_REDIS_DISABLE_SESSION:=0}"
: "${PHPSFX_ONIGURUMA_CLANG_COMPAT:=1}"
