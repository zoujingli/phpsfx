# HyperfAdmin 专用 Swoole CLI 裁剪配置。
# 该文件只使用“默认赋值”，调用方仍可通过环境变量显式覆盖任一项。

: "${PHPSFX_PROFILE_NAME:=hyperfadmin-slim}"

# 仅保留 HyperfAdmin 运行、Phar 发布、外部 public 资源解压和常用数据库/缓存/HTTP 能力需要的扩展。
: "${PHPSFX_EXTENSIONS:=bcmath,ctype,curl,dom,fileinfo,filter,iconv,mbstring,openssl,pcntl,pdo_mysql,phar,posix,redis,simplexml,sockets,sodium,swoole,tokenizer,xml,xmlreader,xmlwriter,zip,zlib}"

# 构建后必须加载的扩展；json/hash/pcre/reflection/PDO/libxml 等由 PHP core 或依赖扩展带出，不作为 prepare.php 显式项。
: "${PHPSFX_REQUIRED_EXTENSIONS:=swoole,redis,pdo_mysql,openssl,curl,mbstring,phar,zlib,zip,dom,simplexml,xmlreader,xmlwriter,fileinfo,bcmath,sodium,sockets}"

# 明确排除当前 HyperfAdmin 未使用或体积较大的扩展，防止官方 full runtime 被误发布为 slim 产物。
: "${PHPSFX_FORBIDDEN_EXTENSIONS:=bz2,exif,gd,gettext,gmp,imagick,intl,mongodb,mysqli,readline,session,soap,sqlite3,xlswriter,xsl,yaml,opcache}"

# Swoole CLI 官方 prepare.php 裁剪参数。+xml 会同时提供 dom/simplexml/xmlreader/xmlwriter 能力。
: "${PHPSFX_SWOOLE_CLI_PREPARE_FLAGS:=+bcmath +ctype +curl +fileinfo +filter +iconv +mbstring +openssl +pcntl +pdo_mysql +phar +posix +redis +sockets +sodium +swoole +tokenizer +xml +zip +zlib -bz2 -exif -gd -gettext -gmp -imagick -intl -mongodb -mysqli -opcache -readline -session -soap -sqlite3 -xlswriter -xsl -yaml}"

# 直接收敛 Swoole CLI 默认启用列表，避免默认 full profile 在 prepare 阶段下载和编译未使用扩展。
: "${PHPSFX_SWOOLE_CLI_ENABLED_EXTENSIONS:=bcmath,ctype,curl,fileinfo,filter,iconv,mbstring,openssl,pcntl,pdo_mysql,phar,posix,redis,sockets,sodium,swoole,tokenizer,xml,zip,zlib}"

# 裁剪 Swoole 扩展自身的可选能力：保留 HyperfAdmin 需要的 server/coroutine/curl/mysqlnd/DNS 能力，
# 移除 pgsql/sqlite/odbc/ssh2/ftp/thread/brotli/zstd 等当前未使用功能和依赖库。
: "${PHPSFX_SWOOLE_SLIM_EXTENSION:=1}"

# 裁剪 curl/libzip 依赖库：保留 HTTP(S)、zlib、OpenSSL、c-ares，移除 HTTP3/SSH2/IDN/PSL/Brotli/Zstd/LZMA/BZip2 等非必需能力。
: "${PHPSFX_CURL_SLIM_LIBRARY:=1}"
: "${PHPSFX_LIBZIP_SLIM_LIBRARY:=1}"
: "${PHPSFX_ZLIB_SLIM_LIBRARY:=1}"
